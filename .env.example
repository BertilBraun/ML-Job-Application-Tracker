GEMINI_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here

# Resume optimizer LLM provider: gemini or openai
RESUME_OPTIMIZER_PROVIDER=openai
GEMINI_MODEL_NAME=gemini-3.1-pro-preview
OPENAI_MODEL_NAME=gpt-5.5

# Search URLs — paste directly from the job site's search results page
LINKEDIN_SEARCH_URL=https://www.linkedin.com/jobs/search-results/?keywords=...
STEPSTONE_SEARCH_URL=https://www.stepstone.de/jobs/...
REMOTEROCKETSHIP_SEARCH_URL=https://www.remoterocketship.com/...
INDEED_SEARCH_URL=https://de.indeed.com/jobs?q=...
